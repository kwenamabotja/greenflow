# Copy to the project root as `.env` when using docker compose (Compose loads `.env` automatically).
#
# Web UI (nginx → static app; `/api` is proxied to the API container)
WEB_PORT=8086

# Optional: API logging
LOG_LEVEL=info

# Clerk — set both for real authentication. If CLERK_PUBLISHABLE_KEY is empty, the API skips
# Clerk middleware (convenient for local Docker; do not use that mode on a public deployment).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Build-time only — bake Clerk into the SPA bundle when building images:
# docker compose build --build-arg VITE_CLERK_PUBLISHABLE_KEY=pk_test_... --build-arg CLERK_PUBLISHABLE_KEY=pk_test_...

# Postgres is not published to the host by default. To reach it from your machine, add under `db:` in compose:
#   ports: ["5432:5432"]
